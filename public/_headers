# Cloudflare static-assets headers (copied verbatim into dist/).
# Astro fingerprints build assets under /_astro/*, so they can be cached forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Downloaded media (images/videos/fonts) — long cache, revalidate occasionally.
/images/*
  Cache-Control: public, max-age=604800
/videos/*
  Cache-Control: public, max-age=604800
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
