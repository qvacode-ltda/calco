---
/**
 * Footer — verbatim clone of the tailwindcss.com site footer.
 *
 * Two sibling regions that slot into the page's parent grid:
 *   1. `.col-start-1.row-start-3` — the <footer> with four link columns.
 *      Mobile: a 2-up flex layout (`flex gap-4 … md:hidden`).
 *      md+:    a bordered 4-col grid (`hidden … md:grid grid-cols-4`) whose
 *              cells carry `border-x border-b border-gray-950/5` hairlines.
 *   2. `.col-start-1.row-start-5` — the copyright + Trademark Policy row and
 *      the System / Light / Dark theme switcher (headlessui radiogroup markup).
 *
 * The before/after ::pseudo elements draw the 200vw hairline wrappers that
 * bleed across the full-bleed gutters. Self-contained: no required props.
 */

const year = new Date().getFullYear();
---

<div
