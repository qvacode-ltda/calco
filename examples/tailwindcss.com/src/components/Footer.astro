        ><a class="hover:underline" href="/brand">Trademark Policy</a>
      </div>
    </div>
  </div>
</div>

<script>
  // Reproduces the headlessui radiogroup behaviour: click to pick System /
  // Light / Dark, persisted to localStorage and applied via the site's global
  // `window._updateTheme` (defined in the layout head).
  const group = document.getElementById("footer-theme-switcher");
  if (group) {
    const radios = Array.from(group.querySelectorAll<HTMLElement>("[data-theme]"));

    const apply = (theme: string) => {
      const update = (window as unknown as { _updateTheme?: (t: string) => void })._updateTheme;
      if (typeof update === "function") update(theme);

      for (const radio of radios) {
        const on = radio.getAttribute("data-theme") === theme;
        if (on) radio.setAttribute("data-checked", "");
        else radio.removeAttribute("data-checked");
        radio.setAttribute("aria-checked", on ? "true" : "false");
        radio.tabIndex = on ? 0 : -1;
      }
    };

    let current = "system";
    try {
      current = localStorage.currentTheme || "system";
    } catch {
      /* ignore */
    }
    apply(current);

    for (const radio of radios) {
      radio.addEventListener("click", () => {
        const theme = radio.getAttribute("data-theme") || "system";
        try {
          localStorage.currentTheme = theme;
        } catch {
          /* ignore */
        }
        apply(theme);
      });
    }
  }
</script>
