{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npx astro:*)",
      "Bash(node scripts/:*)",
      "Bash(npx wrangler dev:*)",
      "Bash(npx wrangler deploy --dry-run)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git worktree:*)",
      "Bash(git init:*)",
      "mcp__playwright",
      "mcp__context7",
      "mcp__plugin_playwright_playwright",
      "mcp__plugin_context7_context7",
      "WebFetch"
    ],
    "ask": ["Bash(npx wrangler deploy:*)"],
    "deny": ["Bash(git push:*)", "Bash(rm -rf:*)"]
  }
}
